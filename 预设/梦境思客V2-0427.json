        {
            "identifier": "6327272d-d815-43d0-b25a-321b82e63fcb",
            "name": "新实验文风",
            "enabled": true,
            "injection_position": 0,
            "injection_depth": 4,
            "injection_order": 100,
            "role": "user",
            "content": "{{setglobalvar::sleep_var_wenfeng::文风设定：\n- 以快节奏网文呈现故事。\n- 杜绝传统名著的矫情。\n- 用对话自己解释自己，不要用动作，比喻或解释去翻译和补充对话。简而言之，对话后直接接不带解释性的动作，禁止出现任何对声音质地、语气、情绪状态的抽象概括，包括但不限于：语气很轻、声音很低、说得平静、带着某种腔调。\n- 遣词造句活灵活现，别太俗套。\n}}",
            "system_prompt": false,
            "marker": false,
            "forbid_overrides": false,
            "injection_trigger": []
        },
        {
            "identifier": "41c63243-7e2d-4a8b-b6e5-1b42ee3bfa35",
            "name": "轻小说文风",
            "enabled": false,
            "injection_position": 0,
            "injection_depth": 4,
            "injection_order": 100,
            "role": "user",
            "content": "{{setglobalvar::sleep_var_wenfeng::文风设定：轻小说\n1. 视角：严格跟随主角的所见、所感、所想。禁止上帝视角解说。\n2. 行文：动作和台词主导叙事，以对话推进剧情，减少情绪描写。\n3. 节奏：段落短小，多用短句。角色对话和心理活动频繁切换，尽量避免超过三行的纯描述段落。\n4. 细节：通过具体的环境、语气词来传递氛围，不堆砌比喻和形容词。\n5. 语言：大量使用口语化独白、内心吐槽和拟声词。叙述语言贴近角色性格，可以适度夸张。}}",
            "system_prompt": false,
            "marker": false,
            "forbid_overrides": false
        },
